&НаКлиенте
Процедура MCP_ОбработатьToolCall(ЗапросJSON)
	MCP_Лог("MCP_TOOL_CALL received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	РежимВыполнения = MCP_ПолучитьСвойство(Запрос, "executionMode", "sync");
	ИдентификаторЗадачи = MCP_ПолучитьСвойство(Запрос, "taskId", "");
	Если РежимВыполнения = "sync" И Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: missing id");
		Возврат;
	КонецЕсли;
	Если РежимВыполнения = "task" И Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: missing taskId");
		Возврат;
	КонецЕсли;

	ИмяИнструмента = MCP_ПолучитьСвойство(Запрос, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура") И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;

	Если ИмяИнструмента = "echo" Тогда
		Текст = MCP_ПолучитьСвойство(Аргументы, "text", "");
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", "Echo " + Текст));
		Результат = Новый Структура("content", Контент);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли ИмяИнструмента = "add" Тогда
		А = MCP_ПолучитьСвойство(Аргументы, "a", 0);
		Б = MCP_ПолучитьСвойство(Аргументы, "b", 0);
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Формат(А + Б, "ЧГ=")));
		Результат = Новый Структура("content", Контент);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли ИмяИнструмента = "long_echo" Тогда
		Если РежимВыполнения <> "task" Тогда
			Ответ = MCP_СформироватьОшибкуОтвет(-32601, "Tool requires task-based invocation");
			MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
			Возврат;
		КонецЕсли;
		Текст = MCP_ПолучитьСвойство(Аргументы, "text", "");
		MCP_ЗапланироватьДолгуюЗадачу(ИдентификаторЗадачи, Текст);
		Возврат;
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32601, "Tool not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗапланироватьДолгуюЗадачу(ИдентификаторЗадачи, Текст)
	Если MCP_ДолгиеЗадачи = Неопределено Тогда
		MCP_ДолгиеЗадачи = Новый Массив;
	КонецЕсли;

	Задача = Новый Структура;
	Задача.Вставить("taskId", ИдентификаторЗадачи);
	Задача.Вставить("text", Текст);
	Задача.Вставить("step", 0);
	Задача.Вставить("totalSteps", 5);
	Задача.Вставить("cancelled", Ложь);
	MCP_ДолгиеЗадачи.Добавить(Задача);

	Попытка
		MCP_Компонента.УстановитьСтатусMCPЗадачи(ИдентификаторЗадачи, "working", "Long echo started");
		Попытка
			MCP_Компонента.УведомитьОПрогрессеMCPЗадачи(ИдентификаторЗадачи, 0.0, 5.0, "Task accepted");
		Исключение
			MCP_Лог("Progress notification skipped: " + ОписаниеОшибки());
		КонецПопытки;
	Исключение
		MCP_Лог("Error preparing long task: " + ОписаниеОшибки());
	КонецПопытки;

	MCP_ПодключитьОбработчикДолгихЗадач();
	MCP_Лог(СтрШаблон("Scheduled long task taskId=%1", ИдентификаторЗадачи));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ПодключитьОбработчикДолгихЗадач()
	Если MCP_ОбработчикДолгихЗадачПодключен Тогда
		Возврат;
	КонецЕсли;
	ПодключитьОбработчикОжидания("MCP_ОбработатьДолгиеЗадачи", 1, Ложь);
	MCP_ОбработчикДолгихЗадачПодключен = Истина;
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОтключитьОбработчикДолгихЗадач()
	Если Не MCP_ОбработчикДолгихЗадачПодключен Тогда
		Возврат;
	КонецЕсли;
	ОтключитьОбработчикОжидания("MCP_ОбработатьДолгиеЗадачи");
	MCP_ОбработчикДолгихЗадачПодключен = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьДолгиеЗадачи() Экспорт
	Если MCP_Компонента = Неопределено Тогда
		MCP_ОтключитьОбработчикДолгихЗадач();
		Возврат;
	КонецЕсли;
	Если MCP_ДолгиеЗадачи = Неопределено Или MCP_ДолгиеЗадачи.Количество() = 0 Тогда
		MCP_ОтключитьОбработчикДолгихЗадач();
		Возврат;
	КонецЕсли;

	Индекс = MCP_ДолгиеЗадачи.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Задача = MCP_ДолгиеЗадачи[Индекс];
		Если MCP_ПолучитьСвойство(Задача, "cancelled", Ложь) Тогда
			MCP_ДолгиеЗадачи.Удалить(Индекс);
			Индекс = Индекс - 1;
			Продолжить;
		КонецЕсли;

		ИдентификаторЗадачи = MCP_ПолучитьСвойство(Задача, "taskId", "");
		Текст = MCP_ПолучитьСвойство(Задача, "text", "");
		Шаг = MCP_ПолучитьСвойство(Задача, "step", 0) + 1;
		ВсегоШагов = MCP_ПолучитьСвойство(Задача, "totalSteps", 5);
		Задача.Вставить("step", Шаг);
		MCP_ДолгиеЗадачи[Индекс] = Задача;

			Попытка
				Если Шаг < ВсегоШагов Тогда
					Попытка
						MCP_Компонента.УведомитьОПрогрессеMCPЗадачи(
							ИдентификаторЗадачи,
							Шаг + 0.0,
							ВсегоШагов + 0.0,
							СтрШаблон("Processing step %1 of %2", Шаг, ВсегоШагов)
						);
					Исключение
						MCP_Лог("Progress notification skipped: " + ОписаниеОшибки());
					КонецПопытки;
				Иначе
					Контент = Новый Массив;
				Контент.Добавить(Новый Структура("type,text", "text", "Long echo " + Текст));
				Результат = Новый Структура("content", Контент);
				Ответ = Новый Структура("result", Результат);
				MCP_Компонента.УстановитьСтатусMCPЗадачи(ИдентификаторЗадачи, "completed", "Long echo finished");
				MCP_Компонента.ЗавершитьMCPЗадачу(
					ИдентификаторЗадачи,
					200,
					"{""Content-Type"":""application/json; charset=utf-8""}",
					MCP_ЗаписатьJSON(Ответ)
				);
				MCP_ДолгиеЗадачи.Удалить(Индекс);
			КонецЕсли;
		Исключение
			MCP_Лог(СтрШаблон("Long task failed taskId=%1 err=%2", ИдентификаторЗадачи, ОписаниеОшибки()));
			Попытка
				MCP_Компонента.УстановитьСтатусMCPЗадачи(ИдентификаторЗадачи, "failed", ОписаниеОшибки());
				ОшибкаОтвет = MCP_СформироватьОшибкуОтвет(-32603, ОписаниеОшибки());
				MCP_Компонента.ЗавершитьMCPЗадачу(
					ИдентификаторЗадачи,
					200,
					"{""Content-Type"":""application/json; charset=utf-8""}",
					MCP_ЗаписатьJSON(ОшибкаОтвет)
				);
			Исключение
			КонецПопытки;
			MCP_ДолгиеЗадачи.Удалить(Индекс);
		КонецПопытки;

		Индекс = Индекс - 1;
	КонецЦикла;

	Если MCP_ДолгиеЗадачи.Количество() = 0 Тогда
		MCP_ОтключитьОбработчикДолгихЗадач();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьОтменуЗадачи(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;

	ИдентификаторЗадачи = MCP_ПолучитьСвойство(Запрос, "taskId", "");
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Если MCP_ДолгиеЗадачи = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Индекс = 0 По MCP_ДолгиеЗадачи.Количество() - 1 Цикл
		Задача = MCP_ДолгиеЗадачи[Индекс];
		Если MCP_ПолучитьСвойство(Задача, "taskId", "") = ИдентификаторЗадачи Тогда
			Задача.Вставить("cancelled", Истина);
			MCP_ДолгиеЗадачи[Индекс] = Задача;
			MCP_Лог(СтрШаблон("Long task cancelled taskId=%1", ИдентификаторЗадачи));
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьResourceRead(ЗапросJSON)
	MCP_Лог("MCP_RESOURCE_READ received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: missing id");
		Возврат;
	КонецЕсли;

	URI = MCP_ПолучитьСвойство(Запрос, "uri", "");
	ШаблонURI = MCP_ПолучитьСвойство(Запрос, "uriTemplate", "");
	АргументыШаблона = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(АргументыШаблона) <> Тип("Структура") И ТипЗнч(АргументыШаблона) <> Тип("Соответствие") Тогда
		АргументыШаблона = Новый Структура;
	КонецЕсли;

	Если URI = "str://demo" Тогда
		Содержимое = Новый Массив;
		Содержимое.Добавить(Новый Структура(
			"uri,mimeType,text",
			URI,
			"text/plain",
			"Demo resource content"
		));
		Результат = Новый Структура("contents", Содержимое);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли URI = "str://current-time" Тогда
		Содержимое = Новый Массив;
		Содержимое.Добавить(Новый Структура(
			"uri,mimeType,text",
			URI,
			"text/plain",
			Строка(ТекущаяДата())
		));
		Результат = Новый Структура("contents", Содержимое);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли ШаблонURI = "str://users/{userId}" Тогда
		ИдентификаторПользователя = MCP_ПолучитьСвойство(АргументыШаблона, "userId", "");
		Содержимое = Новый Массив;
		Содержимое.Добавить(Новый Структура(
			"uri,mimeType,text",
			URI,
			"text/plain",
			"Demo user resource for userId=" + ИдентификаторПользователя
		));
		Результат = Новый Структура("contents", Содержимое);
		Ответ = Новый Структура("result", Результат);
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32002, "Resource not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьPromptGet(ЗапросJSON)
	MCP_Лог("MCP_PROMPT_GET received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: missing id");
		Возврат;
	КонецЕсли;

	ИмяПромпта = MCP_ПолучитьСвойство(Запрос, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура") И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;

	Если ИмяПромпта = "greet" Тогда
		ИмяПользователя = MCP_ПолучитьСвойство(Аргументы, "name", "");
		Текст = "Hello";
		Если ЗначениеЗаполнено(ИмяПользователя) Тогда
			Текст = "Hello, " + ИмяПользователя;
		КонецЕсли;
		Сообщения = Новый Массив;
		Сообщения.Добавить(Новый Структура(
			"role,content",
			"assistant",
			Новый Структура("type,text", "text", Текст)
		));
		Результат = Новый Структура("messages", Сообщения);
		Ответ = Новый Структура("result", Результат);
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32601, "Prompt not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

