&НаКлиенте
Процедура MCP_ДобавитьИнструментДинамически(Команда)
	// Демо: добавить новый инструмент и уведомить клиентов
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("Skipped: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;

	СхемаАргументов = Новый Структура;
	СхемаАргументов.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("a", Новый Структура("type,description", "number", "First number"));
	Свойства.Вставить("b", Новый Структура("type,description", "number", "Second number"));
	СхемаАргументов.Вставить("properties", Свойства);
	Требуемые = Новый Массив;
	Требуемые.Добавить("a");
	Требуемые.Добавить("b");
	СхемаАргументов.Вставить("required", Требуемые);

	Инструмент = Новый Структура(
		"name,description,inputSchema",
		"add",
		"Add two numbers",
		СхемаАргументов
	);

	Попытка
		MCP_Компонента.ЗарегистрироватьИнструмент(MCP_ЗаписатьJSON(Инструмент));
		MCP_Компонента.УведомитьОбИзмененииИнструментов();
		MCP_Лог("Tool 'add' registered and clients notified");
	Исключение
		MCP_Лог("Error: " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОтправитьMcpОтвет(Идентификатор, Данные)
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP response ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	ОтветJSON = MCP_ЗаписатьJSON(Данные);
	Попытка
		Успех = MCP_Компонента.ОтправитьMCPОтвет(Идентификатор, 200, "{""Content-Type"":""application/json; charset=utf-8""}", ОтветJSON);
		MCP_Лог(СтрШаблон("MCP response send id=%1 ok=%2", Идентификатор, Успех));
	Исключение
		MCP_Лог(СтрШаблон("MCP response send error id=%1 err=%2", Идентификатор, ОписаниеОшибки()));
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция MCP_СформироватьОшибкуОтвет(Код, Сообщение)
	Ошибка = Новый Структура("code,message", Код, Сообщение);
	Возврат Новый Структура("error", Ошибка);
КонецФункции

&НаКлиенте
Функция MCP_ПолучитьПараметрИзQuery(Запрос, Имя)
	Если Не ЗначениеЗаполнено(Запрос) Тогда
		Возврат "";
	КонецЕсли;
	Для Каждого Пара Из СтрРазделить(Запрос, "&") Цикл
		Если Не ЗначениеЗаполнено(Пара) Тогда
			Продолжить;
		КонецЕсли;
		ПозицияРавно = Найти(Пара, "=");
		Если ПозицияРавно <= 0 Тогда
			Продолжить;
		КонецЕсли;
		Ключ = Лев(Пара, ПозицияРавно - 1);
		Значение = Сред(Пара, ПозицияРавно + 1);
		Если Ключ = Имя Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции


