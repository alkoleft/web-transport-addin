		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;
	Метод = MCP_ПолучитьСвойство(Запрос, "method", "");
	Если ЗначениеЗаполнено(Метод) Тогда
		MCP_Лог(СтрШаблон("MCP notify: %1", Метод));
		Если Метод = "notifications/initialized" Тогда
			MCP_Лог("Client initialized — ready to receive server notifications");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

