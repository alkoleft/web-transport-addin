&НаКлиенте
Перем ЭкземплярКомпонентыHTTP;
&НаКлиенте
Перем MCP_Компонента;
&НаКлиенте
Перем HTTP_ОтветТела;

&НаКлиенте
Асинх Процедура ПриОткрытии(Отказ)
	
	НомерПорта = 8081;
	Логировать = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьHTTPСервер(Команда)
	
	ПодключитьКомпоненту();
	
	ЭкземплярКомпонентыHTTP = Новый("AddIn.WebTransport.http");
	
	ЭкземплярКомпонентыHTTP.ЗапуститьHTTP(АдресПрослушивания());
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗапуститьMCPСервер(Команда)
	АдресПрослушивания = АдресПрослушивания();
	
	Ждать ПодключитьКомпоненту();
	
	MCP_Компонента = Новый("AddIn.WebTransport.mcp");
	MCP_Компонента.ЗапуститьMCP(АдресПрослушивания, "*", 30);
	
	MCP_ЗарегистрироватьДемоДанные();

	MCP_Лог(СтрШаблон("Server started on %1", АдресПрослушивания));
	
КонецПроцедуры

&НаКлиенте
Процедура ОстановитьMCP(Команда)
	MCP_ОстановитьСервер();
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, ЗапросJSON)
	Если Логировать = Неопределено Тогда
		Логировать = Истина;
	КонецЕсли;
	MCP_Лог(СтрШаблон("External event source=%1 event=%2 data=%3", Источник, Событие, ЗапросJSON));
	
	Если Источник = "WebTransport" Тогда
		Если Событие = "HTTP" Тогда
			MCP_ОбработатьHttpСобытие(ЗапросJSON);
		ИначеЕсли Событие = "MCP_TOOL_CALL" Тогда
			MCP_ОбработатьToolCall(ЗапросJSON);
		ИначеЕсли Событие = "MCP_RESOURCE_READ" Тогда
			MCP_ОбработатьResourceRead(ЗапросJSON);
		ИначеЕсли Событие = "MCP_PROMPT_GET" Тогда
			MCP_ОбработатьPromptGet(ЗапросJSON);
		ИначеЕсли Событие = "MCP_NOTIFICATION" Тогда
			MCP_ОбработатьNotification(ЗапросJSON);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Остановить(Команда)
	ЭкземплярКомпонентыHTTP.ОстановитьHTTP();
	ЭкземплярКомпонентыHTTP = Неопределено;
КонецПроцедуры

&НаКлиенте
Асинх Функция ПодключитьКомпоненту()
	
	Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента", "WebTransport", ТипВнешнейКомпоненты.Native, ТипПодключенияВнешнейКомпоненты.НеИзолированно);
	
	Если Не Подключено Тогда
		Ждать УстановитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента", "WebTransport", ТипВнешнейКомпоненты.Native, ТипПодключенияВнешнейКомпоненты.НеИзолированно);
	КонецЕсли;
	
	Если Не Подключено Тогда
		ВызватьИсключение "Не удалось подключить внешнюю компоненту.";
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

&НаКлиенте
Функция АдресПрослушивания()
	Возврат "127.0.0.1:" + Формат(НомерПорта, "ЧГ=0");
КонецФункции

&НаКлиенте
Функция ПрочитатьJSONСтроку(ТекстJSON)
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
КонецФункции

&НаКлиенте
Функция ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию = Неопределено)
	Попытка
		Возврат ПрочитатьJSONСтроку(ТекстJSON);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

&НаКлиенте
Функция ПолучитьЗначениеJSON(Данные, Имя)
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Если Данные.Свойство(Имя, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат "";
КонецФункции

///////////////////////////////////////////////////////////////////////////////
// MCP client (Model Context Protocol) over WebTransportAddIn
///////////////////////////////////////////////////////////////////////////////

&НаКлиенте
Функция MCP_СоздатьКлиент(Адрес, Заголовки = "", ТаймаутМс = 10000) Экспорт
	ПодключитьКомпоненту();
	Компонента = Новый("AddIn.WebTransport.ws");
	Клиент = Новый Структура(
		"Компонента,Адрес,Заголовки,ТаймаутМс,СледующийИД,Ожидающие,Уведомления",
		Компонента,
		Адрес,
		Заголовки,
		ТаймаутМс,
		1,
		Новый Соответствие,
		Новый Массив
	);
	Возврат Клиент;
КонецФункции

&НаКлиенте
Функция MCP_Подключиться(Клиент) Экспорт
	Возврат Клиент.Компонента.Подключиться(Клиент.Адрес, Клиент.Заголовки);
КонецФункции

&НаКлиенте
Процедура MCP_Отключиться(Клиент) Экспорт
	Клиент.Компонента.Отключиться();
КонецПроцедуры

&НаКлиенте
Функция MCP_Инициализировать(Клиент, ИмяКлиента, ВерсияКлиента) Экспорт
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("protocolVersion", "2025-11-25");
	ПараметрыЗапроса.Вставить("clientInfo", Новый Структура("name,version", ИмяКлиента, ВерсияКлиента));
	ПараметрыЗапроса.Вставить("capabilities", Новый Структура);

	Ответ = MCP_ОтправитьЗапрос(Клиент, "initialize", ПараметрыЗапроса);
	MCP_ОтправитьУведомление(Клиент, "initialized", Неопределено);
	Возврат Ответ;
КонецФункции

&НаКлиенте
Функция MCP_СписокИнструментов(Клиент) Экспорт
	Возврат MCP_ОтправитьЗапрос(Клиент, "tools/list", Новый Структура);
КонецФункции

&НаКлиенте
Функция MCP_ВызватьИнструмент(Клиент, ИмяИнструмента, Аргументы) Экспорт
	ПараметрыЗапроса = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Возврат MCP_ОтправитьЗапрос(Клиент, "tools/call", ПараметрыЗапроса);
КонецФункции

&НаКлиенте
Функция MCP_СписокРесурсов(Клиент) Экспорт
	Возврат MCP_ОтправитьЗапрос(Клиент, "resources/list", Новый Структура);
КонецФункции

&НаКлиенте
Функция MCP_СписокШаблоновРесурсов(Клиент) Экспорт
	Возврат MCP_ОтправитьЗапрос(Клиент, "resources/templates/list", Новый Структура);
КонецФункции

&НаКлиенте
Функция MCP_ПрочитатьРесурс(Клиент, URI) Экспорт
	ПараметрыЗапроса = Новый Структура("uri", URI);
	Возврат MCP_ОтправитьЗапрос(Клиент, "resources/read", ПараметрыЗапроса);
КонецФункции

&НаКлиенте
Функция MCP_СписокПромптов(Клиент) Экспорт
	Возврат MCP_ОтправитьЗапрос(Клиент, "prompts/list", Новый Структура);
КонецФункции

&НаКлиенте
Функция MCP_ПолучитьПромпт(Клиент, ИмяПромпта, Аргументы = Неопределено) Экспорт
	ПараметрыЗапроса = Новый Структура("name", ИмяПромпта);
	Если Аргументы <> Неопределено Тогда
		ПараметрыЗапроса.Вставить("arguments", Аргументы);
	КонецЕсли;
	Возврат MCP_ОтправитьЗапрос(Клиент, "prompts/get", ПараметрыЗапроса);
КонецФункции

&НаКлиенте
Функция MCP_ОтправитьЗапрос(Клиент, Метод, ПараметрыЗапроса) Экспорт
	ИД = Клиент.СледующийИД;
	Клиент.СледующийИД = Клиент.СледующийИД + 1;

	Запрос = MCP_СформироватьЗапросJSON(ИД, Метод, ПараметрыЗапроса);
	Клиент.Компонента.ОтправитьСообщение(Запрос);

	Ответ = MCP_ОжидатьОтвет(Клиент, ИД);
	Если MCP_ПолучитьСвойство(Ответ, "error", Неопределено) <> Неопределено Тогда
		ВызватьИсключение "MCP ошибка: " + MCP_ЗаписатьJSON(Ответ.error);
	КонецЕсли;
	Возврат Ответ;
КонецФункции

&НаКлиенте
Процедура MCP_ОтправитьУведомление(Клиент, Метод, ПараметрыЗапроса) Экспорт
	Уведомление = MCP_СформироватьУведомлениеJSON(Метод, ПараметрыЗапроса);
	Клиент.Компонента.ОтправитьСообщение(Уведомление);
КонецПроцедуры

&НаКлиенте
Функция MCP_ОжидатьОтвет(Клиент, ИД) Экспорт
	Ключ = Строка(ИД);
	Ответ = Неопределено;
	Если Клиент.Ожидающие.Свойство(Ключ, Ответ) Тогда
		Клиент.Ожидающие.Удалить(Ключ);
		Возврат Ответ;
	КонецЕсли;

	Пока Истина Цикл
		Сообщение = Клиент.Компонента.ПолучитьСообщение(Клиент.ТаймаутМс);
		Если Не ЗначениеЗаполнено(Сообщение) Тогда
			ВызватьИсключение "Таймаут ожидания MCP ответа";
		КонецЕсли;

		Данные = ПрочитатьJSONСтроку(Сообщение);
		Если ТипЗнч(Данные) = Тип("Структура") Тогда
			ПолученныйИД = Неопределено;
			Если Данные.Свойство("id", ПолученныйИД) Тогда
				КлючОтвета = Строка(ПолученныйИД);
				Если КлючОтвета = Ключ Тогда
					Возврат Данные;
				Иначе
					Клиент.Ожидающие.Вставить(КлючОтвета, Данные);
				КонецЕсли;
			Иначе
				Клиент.Уведомления.Добавить(Данные);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецФункции

&НаКлиенте
Функция MCP_СформироватьЗапросJSON(ИД, Метод, ПараметрыЗапроса)
	Данные = Новый Структура("jsonrpc,id,method", "2.0", ИД, Метод);
	Если ПараметрыЗапроса <> Неопределено Тогда
		Данные.Вставить("params", ПараметрыЗапроса);
	КонецЕсли;
	Возврат MCP_ЗаписатьJSON(Данные);
КонецФункции

&НаКлиенте
Функция MCP_СформироватьУведомлениеJSON(Метод, ПараметрыЗапроса)
	Данные = Новый Структура("jsonrpc,method", "2.0", Метод);
	Если ПараметрыЗапроса <> Неопределено Тогда
		Данные.Вставить("params", ПараметрыЗапроса);
	КонецЕсли;
	Возврат MCP_ЗаписатьJSON(Данные);
КонецФункции

&НаКлиенте
Функция MCP_ЗаписатьJSON(Данные)
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

&НаКлиенте
Функция MCP_ПолучитьСвойство(Данные, Имя, ЗначениеПоУмолчанию)
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = ЗначениеПоУмолчанию;
		Если Данные.Свойство(Имя, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Значение = Данные.Получить(Имя);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

///////////////////////////////////////////////////////////////////////////////
// MCP server (Streamable HTTP)
///////////////////////////////////////////////////////////////////////////////

&НаКлиенте
Процедура MCP_Лог(Текст)
	Если Логировать = Ложь Тогда
		Возврат;
	КонецЕсли;
	Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
	Сообщить(СтрШаблон("[MCP %1] %2", Время, Текст));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОстановитьСервер() Экспорт
	Если MCP_Компонента <> Неопределено Тогда
		MCP_Компонента.ОстановитьMCP();
		MCP_Компонента = Неопределено;
	КонецЕсли;
	MCP_Лог("Server stopped");
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьHttpСобытие(ЗапросJSON)
	Если ЭкземплярКомпонентыHTTP = Неопределено Тогда
		MCP_Лог("HTTP event ignored: ЭкземплярКомпонентыHTTP is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("HTTP event ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	MCP_Лог(СтрШаблон("HTTP event data=%1", ЗапросJSON));
	ЗапросДанные = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(ЗапросДанные) <> Тип("Структура") И ТипЗнч(ЗапросДанные) <> Тип("Соответствие") Тогда
		MCP_Лог("HTTP event ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = ЗапросДанные.Получить("id");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("HTTP event ignored: missing id");
		Возврат;
	КонецЕсли;
	ЗаголовкиОтвета = "{""Content-Type"":""text/plain; charset=utf-8""}";
	ТелоОтвета = HTTP_ОтветТела;
	Если Не ЗначениеЗаполнено(ТелоОтвета) Тогда
		ТелоОтвета = ЗапросJSON;
	КонецЕсли;
	ЭкземплярКомпонентыHTTP.ОтправитьHTTPОтвет(Идентификатор, 200, ЗаголовкиОтвета, ТелоОтвета);
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗарегистрироватьДемоДанные()
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("Registration skipped: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;

	MCP_Компонента.ОчиститьИнструменты();
	MCP_Компонента.ОчиститьРесурсы();
	MCP_Компонента.ОчиститьШаблоныРесурсов();
	MCP_Компонента.ОчиститьПромпты();

	MCP_ЗарегистрироватьИнструменты();
	MCP_ЗарегистрироватьРесурсы();
	MCP_ЗарегистрироватьШаблоныРесурсов();
	MCP_ЗарегистрироватьПромпты();
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗарегистрироватьИнструменты()
	СхемаАргументов = Новый Структура;
	СхемаАргументов.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("text", Новый Структура("type", "string"));
	СхемаАргументов.Вставить("properties", Свойства);
	Требуемые = Новый Массив;
	Требуемые.Добавить("text");
	СхемаАргументов.Вставить("required", Требуемые);

	Инструмент = Новый Структура(
		"name,description,inputSchema",
		"echo",
		"Echo input text",
		СхемаАргументов
	);

	MCP_Компонента.ЗарегистрироватьИнструмент(MCP_ЗаписатьJSON(Инструмент));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗарегистрироватьРесурсы()
	Ресурс = Новый Структура(
		"uri,name,description,mimeType",
		"str://demo",
		"demo",
		"Demo resource",
		"text/plain"
	);
	MCP_Компонента.ЗарегистрироватьРесурс(MCP_ЗаписатьJSON(Ресурс));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗарегистрироватьШаблоныРесурсов()
	ШаблонРесурса = Новый Структура(
		"uriTemplate,name,description,mimeType",
		"str://users/{userId}",
		"user-by-id",
		"Demo template resource",
		"text/plain"
	);
	MCP_Компонента.ЗарегистрироватьШаблонРесурса(MCP_ЗаписатьJSON(ШаблонРесурса));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ЗарегистрироватьПромпты()
	Аргументы = Новый Массив;
	Аргумент = Новый Структура("name,description,required", "name", "User name", Истина);
	Аргументы.Добавить(Аргумент);

	Промпт = Новый Структура(
		"name,description,arguments",
		"greet",
		"Greeting prompt",
		Аргументы
	);
	MCP_Компонента.ЗарегистрироватьПромпт(MCP_ЗаписатьJSON(Промпт));
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьToolCall(ЗапросJSON)
	MCP_Лог("MCP_TOOL_CALL received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_TOOL_CALL ignored: missing id");
		Возврат;
	КонецЕсли;

	ИмяИнструмента = MCP_ПолучитьСвойство(Запрос, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура") И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;

	Если ИмяИнструмента = "echo" Тогда
		Текст = MCP_ПолучитьСвойство(Аргументы, "text", "");
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", "Echo " + Текст));
		Результат = Новый Структура("content", Контент);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли ИмяИнструмента = "add" Тогда
		А = MCP_ПолучитьСвойство(Аргументы, "a", 0);
		Б = MCP_ПолучитьСвойство(Аргументы, "b", 0);
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Формат(А + Б, "ЧГ=")));
		Результат = Новый Структура("content", Контент);
		Ответ = Новый Структура("result", Результат);
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32601, "Tool not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьResourceRead(ЗапросJSON)
	MCP_Лог("MCP_RESOURCE_READ received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_RESOURCE_READ ignored: missing id");
		Возврат;
	КонецЕсли;

	URI = MCP_ПолучитьСвойство(Запрос, "uri", "");
	ШаблонURI = MCP_ПолучитьСвойство(Запрос, "uriTemplate", "");
	АргументыШаблона = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(АргументыШаблона) <> Тип("Структура") И ТипЗнч(АргументыШаблона) <> Тип("Соответствие") Тогда
		АргументыШаблона = Новый Структура;
	КонецЕсли;

	Если URI = "str://demo" Тогда
		Содержимое = Новый Массив;
		Содержимое.Добавить(Новый Структура(
			"uri,mimeType,text",
			URI,
			"text/plain",
			"Demo resource content"
		));
		Результат = Новый Структура("contents", Содержимое);
		Ответ = Новый Структура("result", Результат);
	ИначеЕсли ШаблонURI = "str://users/{userId}" Тогда
		ИдентификаторПользователя = MCP_ПолучитьСвойство(АргументыШаблона, "userId", "");
		Содержимое = Новый Массив;
		Содержимое.Добавить(Новый Структура(
			"uri,mimeType,text",
			URI,
			"text/plain",
			"Demo user resource for userId=" + ИдентификаторПользователя
		));
		Результат = Новый Структура("contents", Содержимое);
		Ответ = Новый Структура("result", Результат);
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32002, "Resource not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

&НаКлиенте
Процедура MCP_ОбработатьPromptGet(ЗапросJSON)
	MCP_Лог("MCP_PROMPT_GET received");
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: MCP_Компонента is undefined");
		Возврат;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: empty request JSON");
		Возврат;
	КонецЕсли;
	Запрос = ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура") И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: request is not object");
		Возврат;
	КонецЕсли;
	Идентификатор = MCP_ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		MCP_Лог("MCP_PROMPT_GET ignored: missing id");
		Возврат;
	КонецЕсли;

	ИмяПромпта = MCP_ПолучитьСвойство(Запрос, "name", "");
	Аргументы = MCP_ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура") И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;

	Если ИмяПромпта = "greet" Тогда
		ИмяПользователя = MCP_ПолучитьСвойство(Аргументы, "name", "");
		Текст = "Hello";
		Если ЗначениеЗаполнено(ИмяПользователя) Тогда
			Текст = "Hello, " + ИмяПользователя;
		КонецЕсли;
		Сообщения = Новый Массив;
		Сообщения.Добавить(Новый Структура(
			"role,content",
			"assistant",
			Новый Структура("type,text", "text", Текст)
		));
		Результат = Новый Структура("messages", Сообщения);
		Ответ = Новый Структура("result", Результат);
	Иначе
		Ответ = MCP_СформироватьОшибкуОтвет(-32601, "Prompt not found");
	КонецЕсли;

	MCP_ОтправитьMcpОтвет(Идентификатор, Ответ);
КонецПроцедуры

