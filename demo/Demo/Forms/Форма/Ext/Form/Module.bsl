&НаКлиенте
Перем MCP_Компонента;
&НаКлиенте
Перем НомерПортаMCP;
&НаКлиенте
Перем MCP_ДолгиеЗадачи;
&НаКлиенте
Перем MCP_ОбработчикДолгихЗадачПодключен;

&НаКлиенте
Асинх Процедура ПриОткрытии(Отказ)

	НомерПортаMCP = 8082;
	Логировать = Истина;
	MCP_ДолгиеЗадачи = Новый Массив;
	MCP_ОбработчикДолгихЗадачПодключен = Ложь;

	Ждать ПодключитьКомпоненту();
	MCP_ДолгиеЗадачи = Новый Массив;
	MCP_ОбработчикДолгихЗадачПодключен = Ложь;

	MCP_Компонента = Новый("AddIn.WebTransport.mcp");

	ИнформацияОСервере = Новый Структура;
	ИнформацияОСервере.Вставить("name", "1c-demo-mcp-server");
	ИнформацияОСервере.Вставить("version", "1.0.0");
	ИнформацияОСервере.Вставить("title", "1C:Enterprise Demo MCP Server");
	ИнформацияОСервере.Вставить("description", "MCP server powered by 1C:Enterprise");
	ИнформацияОСервере.Вставить("instructions", "Use tools to interact with 1C:Enterprise");
	MCP_Компонента.УстановитьИнформациюОСервере(MCP_ЗаписатьJSON(ИнформацияОСервере));

	MCP_Компонента.ЗапуститьMCP(АдресПрослушиванияMCP(), "*", 30);

	MCP_ЗарегистрироватьДемоДанные();

	MCP_Лог(СтрШаблон("MCP server started on %1", АдресПрослушиванияMCP()));

КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗапуститьMCPСервер(Команда)
	Ждать ПодключитьКомпоненту();
	MCP_ДолгиеЗадачи = Новый Массив;
	MCP_ОбработчикДолгихЗадачПодключен = Ложь;

	MCP_Компонента = Новый("AddIn.WebTransport.mcp");

	ИнформацияОСервере = Новый Структура;
	ИнформацияОСервере.Вставить("name", "1c-demo-mcp-server");
	ИнформацияОСервере.Вставить("version", "1.0.0");
	ИнформацияОСервере.Вставить("title", "1C:Enterprise Demo MCP Server");
	ИнформацияОСервере.Вставить("description", "MCP server powered by 1C:Enterprise");
	ИнформацияОСервере.Вставить("instructions", "Use tools to interact with 1C:Enterprise");
	MCP_Компонента.УстановитьИнформациюОСервере(MCP_ЗаписатьJSON(ИнформацияОСервере));

	MCP_Компонента.ЗапуститьMCP(АдресПрослушиванияMCP(), "*", 30);

	MCP_ЗарегистрироватьДемоДанные();

	MCP_Лог(СтрШаблон("MCP server started on %1", АдресПрослушиванияMCP()));

КонецПроцедуры

&НаКлиенте
Процедура ОстановитьMCP(Команда)
	MCP_ОстановитьСервер();
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, ЗапросJSON)
	Если Логировать = Неопределено Тогда
		Логировать = Истина;
	КонецЕсли;
	MCP_Лог(СтрШаблон("External event source=%1 event=%2 data=%3", Источник, Событие, ЗапросJSON));

	Если Источник = "WebTransport" Тогда
		Если Событие = "MCP_TOOL_CALL" Тогда
			MCP_ОбработатьToolCall(ЗапросJSON);
		ИначеЕсли Событие = "MCP_TASK_CANCELLED" Тогда
			MCP_ОбработатьОтменуЗадачи(ЗапросJSON);
		ИначеЕсли Событие = "MCP_RESOURCE_READ" Тогда
			MCP_ОбработатьResourceRead(ЗапросJSON);
		ИначеЕсли Событие = "MCP_PROMPT_GET" Тогда
			MCP_ОбработатьPromptGet(ЗапросJSON);
		ИначеЕсли Событие = "MCP_NOTIFICATION" Тогда
			MCP_ОбработатьNotification(ЗапросJSON);
		ИначеЕсли Событие = "MCP_RESOURCE_SUBSCRIBE" Тогда
			MCP_ОбработатьResourceSubscribe(ЗапросJSON);
		ИначеЕсли Событие = "MCP_RESOURCE_UNSUBSCRIBE" Тогда
			MCP_ОбработатьResourceUnsubscribe(ЗапросJSON);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Асинх Функция ПодключитьКомпоненту()
	
	Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента", "WebTransport", ТипВнешнейКомпоненты.Native, ТипПодключенияВнешнейКомпоненты.НеИзолированно);
	
	Если Не Подключено Тогда
		Ждать УстановитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх("ВнешняяОбработка.Demo.Макет.Компонента", "WebTransport", ТипВнешнейКомпоненты.Native, ТипПодключенияВнешнейКомпоненты.НеИзолированно);
	КонецЕсли;
	
	Если Не Подключено Тогда
		ВызватьИсключение "Не удалось подключить внешнюю компоненту.";
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

&НаКлиенте
Функция АдресПрослушиванияMCP()
	Если НомерПортаMCP = Неопределено Тогда
		НомерПортаMCP = 8082;
	КонецЕсли;
	Возврат "127.0.0.1:" + Формат(НомерПортаMCP, "ЧГ=0");
КонецФункции

&НаКлиенте
Функция ПрочитатьJSONСтроку(ТекстJSON)
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
КонецФункции

&НаКлиенте
Функция ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию = Неопределено)
	Попытка
		Возврат ПрочитатьJSONСтроку(ТекстJSON);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

&НаКлиенте
Функция ПолучитьЗначениеJSON(Данные, Имя)
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = Неопределено;
		Если Данные.Свойство(Имя, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат "";
КонецФункции

